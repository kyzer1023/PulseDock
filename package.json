{
  "name": "pulsedock",
  "version": "0.1.1",
  "private": true,
  "description": "Windows-first tray utility for local Codex and Cursor usage snapshots.",
  "author": "kyzer1023",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyzer1023/PulseDock.git"
  },
  "bugs": {
    "url": "https://github.com/kyzer1023/PulseDock/issues"
  },
  "homepage": "https://github.com/kyzer1023/PulseDock#readme",
  "type": "module",
  "main": "dist-electron/electron/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:preload\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:preload": "vite build --config vite.preload.config.ts --watch",
    "dev:app": "wait-on tcp:5173 dist-electron/electron/main/main.js dist-electron/electron/preload/index.cjs && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:electron": "tsc -p tsconfig.electron.json && npm run build:preload",
    "test": "npm run build:electron && node --test test/*.test.mjs",
    "dist:dir": "npm run build && electron-builder --win dir -c.directories.output=release-smoke",
    "test:packaged": "npm run dist:dir && node --test test/packaged-app-smoke.packaged.mjs",
    "dist": "npm run build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^38.1.2",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.kyzer.pulsedock",
    "productName": "PulseDock",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "assets/icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    }
  }
}
