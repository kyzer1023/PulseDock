{
  "name": "pulsedock",
  "version": "0.1.3",
  "private": true,
  "description": "Windows-first tray utility for local Codex and Cursor usage snapshots.",
  "author": "kyzer1023",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/kyzer1023/PulseDock.git"
  },
  "bugs": {
    "url": "https://github.com/kyzer1023/PulseDock/issues"
  },
  "homepage": "https://github.com/kyzer1023/PulseDock#readme",
  "type": "module",
  "scripts": {
    "dev": "npm run tauri:dev",
    "dev:renderer": "vite",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build": "npm run build:renderer",
    "build:renderer": "vite build",
    "test": "node scripts/rust-runner.mjs test",
    "test:packaged": "npm run dist && node --test test/packaged-app-smoke.packaged.mjs",
    "dist": "npm run tauri:build",
    "tauri:dev": "node scripts/tauri-runner.mjs dev",
    "tauri:build": "node scripts/tauri-runner.mjs build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.7"
  }
}
