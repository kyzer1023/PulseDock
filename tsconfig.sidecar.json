{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": [
      "node"
    ],
    "noEmit": true
  },
  "include": [
    "app/src/application",
    "app/src/domain",
    "app/src/providers",
    "sidecar/**/*.ts"
  ]
}
