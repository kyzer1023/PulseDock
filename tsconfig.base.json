{
  "compilerOptions": {
    "target": "ES2022",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@application/*": [
        "app/src/application/*"
      ],
      "@domain/*": [
        "app/src/domain/*"
      ],
      "@providers/*": [
        "app/src/providers/*"
      ],
      "@renderer/*": [
        "app/src/*"
      ],
      "@styles/*": [
        "app/src/styles/*"
      ]
    }
  }
}
